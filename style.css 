* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: Arial, sans-serif;
  background-color: #dfe8ec;
  color: #333;
  padding: 2rem;
}

header {
  background-color: #151738;
  color: white;
  padding: 2rem;
  border-radius: 18px;
  margin-bottom: 2rem;
}

h1 {
  font-size: 3rem;
  line-height: 1.1;
  margin-bottom: 1rem;
}

header p {
  font-size: 1.1rem;
  color: #f1f1f1;
}

main {
  background-color: #f3f3f3;
  padding: 2rem;
  border-radius: 18px;
  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.12);
}

main p {
  font-size: 1.15rem;
  margin-bottom: 0.8rem;
  line-height: 1.35;
}